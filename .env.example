# Database Configuration (Postgres with pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/crm

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Storage (R2 / S3 compatible)
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY=your-r2-access-key
S3_SECRET_KEY=your-r2-secret-key
S3_BUCKET=renovation-media
S3_SECURE=true

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256

# Telegram Bot
TELEGRAM_BOT_TOKEN=8333397402:AAFaYx-Q1bMlo_2hwbyqdzSFH2PZ6eJenw8
TELEGRAM_WEBHOOK_URL=https://isaev_back.karpix.com/api/webhook/telegram
MANAGER_TELEGRAM_ID=
TELEGRAM_PHONE_LOOKUP_MAX_PER_MINUTE=20
TELEGRAM_PHONE_LOOKUP_CACHE_TTL_SECONDS=3600
WHATSAPP_LOOKUP_URL=
WHATSAPP_LOOKUP_TOKEN=
WHATSAPP_LOOKUP_METHOD=post
WHATSAPP_LOOKUP_TIMEOUT_SECONDS=10
WHATSAPP_LOOKUP_MAX_PER_MINUTE=20

# Novofon Click-to-Call
NOVOFON_API_BASE_URL=https://callapi-jsonrpc.novofon.ru/v4.0
NOVOFON_LOGIN=
NOVOFON_PASSWORD=
NOVOFON_ACCESS_TOKEN=
NOVOFON_VIRTUAL_PHONE_NUMBER=
NOVOFON_DIAL_URL_TEMPLATE=tel:{phone}
NOVOFON_DEFAULT_OPERATOR_PHONE=
NOVOFON_BUSINESS_CARD_MESSAGE=Спасибо за звонок! Это наша визитка.
NOVOFON_BUSINESS_CARD_TEMPLATE=Спасибо за звонок!\nЭто визитка компании {company_name}.\nМенеджер: {manager_name}\nТелефон: {manager_phone}\n{site_line}\n{telegram_line}
NOVOFON_BUSINESS_CARD_SITE_URL=
NOVOFON_BUSINESS_CARD_TELEGRAM=
NOVOFON_WEBHOOK_SECRET=
NOVOFON_TIMEOUT_SECONDS=15

# OpenRouter (AI)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# App Config
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=https://isaev_crm.karpix.com
