# Database Configuration (Postgres with pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/crm

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Storage (R2 / S3 compatible)
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY=your-r2-access-key
S3_SECRET_KEY=your-r2-secret-key
S3_BUCKET=renovation-media
S3_SECURE=true

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBHOOK_URL=https://your-api-domain.example.com/api/webhook/telegram
TELEGRAM_WEBHOOK_SECRET_TOKEN=change-this-secret-token
MANAGER_TELEGRAM_ID=
TELEGRAM_PHONE_LOOKUP_MAX_PER_MINUTE=20
TELEGRAM_PHONE_LOOKUP_CACHE_TTL_SECONDS=3600
TELEGRAM_BUSINESS_CARD_DEFAULT_TEMPLATE=Здравствуйте, {{client_name}}!\n\nСпасибо за звонок 🙌\n\nЯ {{operator_name}}, менеджер компании {{company_name}}.\nЕсли будут вопросы — пишите сюда в Telegram.
WHATSAPP_LOOKUP_URL=
WHATSAPP_LOOKUP_TOKEN=
WHATSAPP_LOOKUP_METHOD=post
WHATSAPP_LOOKUP_TIMEOUT_SECONDS=10
WHATSAPP_LOOKUP_MAX_PER_MINUTE=20
USERBOT_PENDING_MESSAGE_BATCH_SIZE=100

# Cal.com / Cal Pro measurement scheduling
CAL_PRO_ENABLED=false
CAL_PRO_API_BASE_URL=https://api.cal.com
CAL_PRO_API_KEY=your-cal-pro-api-key
CAL_PRO_SLOTS_API_VERSION=2024-09-04
CAL_PRO_BOOKINGS_API_VERSION=2026-02-25
CAL_PRO_EVENT_TYPE_ID=
CAL_PRO_EVENT_TYPE_SLUG=free-measurement
CAL_PRO_USERNAME=your-cal-username
CAL_PRO_TEAM_SLUG=
CAL_PRO_ORGANIZATION_SLUG=
CAL_PRO_TIME_ZONE=Europe/Moscow
CAL_PRO_DURATION_MINUTES=60
CAL_PRO_SLOT_DAYS_AHEAD=14
CAL_PRO_MAX_SLOTS=12

# Wazzup WhatsApp channel
WAZZUP_ENABLED=false
WAZZUP_API_BASE_URL=https://api.wazzup24.com/v3
WAZZUP_API_KEY=
WAZZUP_DEFAULT_CHANNEL_ID=
WAZZUP_WEBHOOK_TOKEN=
WAZZUP_TIMEOUT_SECONDS=15

# OpenRouter (AI)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# App Config
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
PUBLIC_QUIZ_URL=https://your-crm-domain.example.com/quiz-remont.html
AUTO_CREATE_TABLES=false
BACKGROUND_JOB_BATCH_SIZE=25
BACKGROUND_JOB_POLL_INTERVAL_SECONDS=5
BACKGROUND_JOB_LOCK_TIMEOUT_SECONDS=900
CORS_ORIGINS=https://your-crm-domain.example.com

# PostHog Cloud analytics
POSTHOG_ENABLED=false
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_API_KEY=phc_your_project_api_key
POSTHOG_TIMEOUT_SECONDS=3
